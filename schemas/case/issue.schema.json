{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue.schema.json",
  "title": "Issue",
  "description": "争点对象 - 案件中的争议焦点",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issue_id",
    "case_id",
    "title",
    "issue_type",
    "fact_propositions"
  ],
  "properties": {
    "issue_id": {
      "type": "string",
      "minLength": 1,
      "description": "争点唯一标识"
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "争点标题"
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "factual",
        "legal",
        "procedural",
        "mixed"
      ],
      "description": "争点类型"
    },
    "parent_issue_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "父争点ID，用于层级结构（平铺列表，非嵌套JSON）"
    },
    "related_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "关联的诉讼请求ID"
    },
    "related_defense_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "关联的抗辩ID"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "关联的证据ID"
    },
    "burden_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "关联的举证责任ID"
    },
    "fact_propositions": {
      "type": "array",
      "description": "Structured fact propositions that bridge evidence to issues",
      "items": {
        "type": "object",
        "properties": {
          "proposition_id": {
            "type": "string",
            "description": "Unique identifier for this fact proposition"
          },
          "text": {
            "type": "string",
            "description": "The fact proposition statement"
          },
          "status": {
            "type": "string",
            "enum": [
              "unverified",
              "supported",
              "contradicted",
              "disputed"
            ],
            "description": "Current verification status"
          },
          "linked_evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Evidence IDs supporting or contradicting this proposition"
          }
        },
        "required": [
          "proposition_id",
          "text"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved",
        "deferred"
      ],
      "description": "争点当前状态"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
