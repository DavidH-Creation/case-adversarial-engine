      "parent_issue_id": "issue-civil-loan-005-001",
      "related_claim_ids": ["claim-civil-loan-005-001"],
      "related_defense_ids": ["defense-civil-loan-005-002"],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-005-003",
          "text": "农信社股金不等同于公司股权，不属于《物权法》第226条规定的'其他股权'出质范围，不属于工商行政管理部门办理出质登记的范围",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-005-004",
          "text": "出质人向质权人交付了股金证，且办理了冻结止付登记手续，出质股金不能再流通",
          "status": "unverified",
          "linked_evidence_ids": ["evidence-civil-loan-005-003", "evidence-civil-loan-005-004"]
        }
      ],
      "burden_ids": ["burden-civil-loan-005-002"],
      "evidence_ids": ["evidence-civil-loan-005-003", "evidence-civil-loan-005-004"],
      "status": "open"
    },
