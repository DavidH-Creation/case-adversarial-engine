      "case_id": "civil-loan-017",
      "title": "合同中预先约定债权转让后由受让人住所地法院管辖的条款是否有效",
      "issue_type": "legal",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-017-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-017-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-017-001",
          "text": "原始借款合同中包含管辖约定条款，约定债权转让后争议由受让人住所地法院管辖",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-017-001"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-017-002",
          "text": "该管辖条款系合同当事人为第三方（即未来不确定的债权受让方）涉诉而约定的协议管辖",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-017-001"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-017-003",
          "text": "债权受让方在合同订立时不确定，亦不可能参与缔结该协议管辖条款",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
      "burden_ids": [
