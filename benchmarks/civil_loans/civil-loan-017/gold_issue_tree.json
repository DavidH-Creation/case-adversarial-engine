      ],
      "status": "open"
    },
    {
      "issue_id": "issue-civil-loan-017-002",
      "case_id": "civil-loan-017",
      "title": "受让方所在地是否属于订立合同时与争议有实际联系的地点",
      "issue_type": "legal",
      "parent_issue_id": "issue-civil-loan-017-001",
      "related_claim_ids": [
        "claim-civil-loan-017-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-017-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-017-004",
          "text": "《民事诉讼法》第35条规定协议管辖须选择与争议有实际联系地点的法院",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-017-005",
          "text": "合同订立时债权受让方尚不存在或不确定，其住所地在订立合同时与争议不具有实际联系",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-017-002",
            "evidence-civil-loan-017-003"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-017-006",
          "text": "与争议有实际联系的地点应限于被告住所地、合同履行地、合同签订地、原告住所地、标的物所在地等法定地点",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
