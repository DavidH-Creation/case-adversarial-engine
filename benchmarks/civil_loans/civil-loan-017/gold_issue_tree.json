          "text": "债权已从原出借人转让至原告（受让人），债权转让通知已送达被告",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-017-004",
            "evidence-civil-loan-017-005"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-017-008",
          "text": "预先约定的受让人住所地管辖条款无效后，应回归法定管辖或原合同中其他有效的管辖约定",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-017-009",
          "text": "债权转让不影响原合同中其他有效管辖条款对受让人的约束力",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-017-001"
          ]
        }
      ],
