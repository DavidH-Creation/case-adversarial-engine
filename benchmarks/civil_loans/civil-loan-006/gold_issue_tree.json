        },
        {
          "proposition_id": "fp-civil-loan-006-005",
          "text": "出借人通过要求借款人在放款前/同日支付利息的方式，实质上预先扣除了本金中的利息部分",
          "status": "unverified",
          "linked_evidence_ids": ["evidence-civil-loan-006-003", "evidence-civil-loan-006-005"]
        }
