      "parent_issue_id": "issue-civil-loan-006-003",
      "related_claim_ids": ["claim-civil-loan-006-004"],
      "related_defense_ids": ["defense-civil-loan-006-004"],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-006-008",
          "text": "出借人以合同约定的借款金额（而非实际出借金额）为基数计算利息，构成重复计息或高于实际出借本金计息",
          "status": "unverified",
          "linked_evidence_ids": ["evidence-civil-loan-006-005"]
        },
        {
          "proposition_id": "fp-civil-loan-006-009",
          "text": "利息的支付应以借款人实际占有借款为前提，利息基数应为实际出借本金金额",
          "status": "unverified",
          "linked_evidence_ids": ["evidence-civil-loan-006-004", "evidence-civil-loan-006-005"]
        }
      ],
      "burden_ids": ["burden-civil-loan-006-004"],
