      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-008-005",
          "text": "典当公司在银行开设有结算账户，账户内资金归属于典当公司",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-008-005"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-008-006",
          "text": "银行将款项汇入典当公司账户并备注为履行生效判决，该款项进入账户后即归属典当公司",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-008-006",
            "evidence-civil-loan-008-007"
          ]
        }
