      "issue_id": "issue-civil-loan-008-004",
      "case_id": "civil-loan-008",
      "title": "银行扣划典当公司账户存款是否符合合同约定（依约扣收的效力）",
      "issue_type": "mixed",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-008-003"
