      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-008-009",
          "text": "银行与典当公司签订的借款合同中约定银行有权从典当公司账户中扣收到期债务",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-008-008"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-008-010",
          "text": "银行实际从典当公司账户中扣划了相应款项用于偿还借款债务",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-008-009"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-008-011",
          "text": "银行的扣划行为系依据合同约定的扣收权实施，属于依约扣收",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-008-008",
            "evidence-civil-loan-008-009"
          ]
        }
      ],
