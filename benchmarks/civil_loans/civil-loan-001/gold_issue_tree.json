      "case_id": "civil-loan-001",
      "title": "本案是否构成\"以新贷偿还旧贷\"（借新还旧事实认定）",
      "issue_type": "factual",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-001-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-001-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-001-001",
          "text": "债权人与借款人之间存在旧贷借款关系且旧贷尚未清偿",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-001",
            "evidence-civil-loan-001-002"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-001-002",
          "text": "债权人与借款人又订立新的借款合同（新贷）",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-003"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-001-003",
          "text": "新贷款项实际用于偿还旧贷本息，资金流向可追溯",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-004",
            "evidence-civil-loan-001-005"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-001-004",
          "text": "主合同当事人（债权人与借款人）之间就以新贷偿还旧贷存在合意或协议",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-003",
            "evidence-civil-loan-001-004"
          ]
        }
      ],
      "burden_ids": [
