    {
      "issue_id": "issue-civil-loan-001-002",
      "case_id": "civil-loan-001",
      "title": "\"以新贷偿还旧贷\"是否要求新贷与旧贷借款人为同一民事主体",
      "issue_type": "legal",
      "parent_issue_id": "issue-civil-loan-001-001",
      "related_claim_ids": [
        "claim-civil-loan-001-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-001-002"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-001-005",
          "text": "《担保法司法解释》第39条第1款规定的\"以新贷偿还旧贷\"系就借款用途对保证人利益影响所作规定，不以新旧贷借款人同一为要件",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-001-006",
          "text": "保证人不承担责任的原因是\"偿还旧贷\"增加代偿风险，而非主体是否同一",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
      "burden_ids": [],
      "evidence_ids": [],
      "status": "open"
    },
    {
      "issue_id": "issue-civil-loan-001-003",
      "case_id": "civil-loan-001",
      "title": "保证人对借新还旧事实是否知道或应当知道",
      "issue_type": "mixed",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-001-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-001-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-001-007",
          "text": "保证人签订保证合同时不知道新贷的实际用途为偿还旧贷",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-006",
            "evidence-civil-loan-001-007"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-001-008",
          "text": "保证人基于对新贷系用于生产经营等其他用途的信赖而提供担保",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-006"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-001-009",
          "text": "保证人无从通过合理注意义务获知借新还旧的事实（不应当知道）",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-007"
          ]
        }
      ],
      "burden_ids": [
        "burden-civil-loan-001-002",
        "burden-civil-loan-001-003"
      ],
      "evidence_ids": [
        "evidence-civil-loan-001-006",
