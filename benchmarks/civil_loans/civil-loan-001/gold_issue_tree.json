      ],
      "status": "open"
    },
    {
      "issue_id": "issue-civil-loan-001-004",
      "case_id": "civil-loan-001",
      "title": "不知情保证人是否应免除保证责任（《担保法司法解释》第39条第1款的适用）",
      "issue_type": "legal",
      "parent_issue_id": "issue-civil-loan-001-003",
      "related_claim_ids": [
        "claim-civil-loan-001-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-001-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-001-010",
          "text": "借款用途是保证人据以判断借款人还款能力、决定是否提供担保的重要甚至关键考虑因素",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-001-011",
          "text": "为\"偿还旧贷\"目的的借款提供保证，客观上增加保证人代主债务人承担还款责任的发生风险",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-001-012",
          "text": "保证人基于对其他借款用途的信赖而提供担保的缔约基础不复存在，应免除保证责任",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
      "burden_ids": [
        "burden-civil-loan-001-004"
      ],
      "evidence_ids": [],
      "status": "open"
    },
    {
      "issue_id": "issue-civil-loan-001-005",
      "case_id": "civil-loan-001",
      "title": "新贷与旧贷系同一保证人时，保证人是否仍应承担保证责任",
      "issue_type": "legal",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-001-002"
      ],
      "related_defense_ids": [
        "defense-civil-loan-001-003"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-001-013",
          "text": "该保证人同时为旧贷和新贷提供了保证担保",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-001-008",
            "evidence-civil-loan-001-006"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-001-014",
          "text": "借新还旧导致旧贷主合同及保证合同权利义务终止，保证人不再承担旧贷保证责任",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-001-015",
          "text": "对新旧贷同一保证人而言，其风险总量并未因借新还旧而增加，仍应承担新贷保证责任",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
