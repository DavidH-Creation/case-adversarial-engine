      "issue_id": "issue-civil-loan-012-002",
      "case_id": "civil-loan-012",
      "title": "立案受理阶段的审查标准——形式审查与实体审查的界限",
      "issue_type": "procedural",
      "parent_issue_id": "issue-civil-loan-012-001",
      "related_claim_ids": [
        "claim-civil-loan-012-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-012-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-012-003",
          "text": "立案受理阶段法院仅需审查原告是否提交了证明借贷法律关系存在的初步证据",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-012-004",
          "text": "出借人经济状况、款项来源、实际出借能力等属于实体审查范畴，不应在立案阶段审查",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-012-005",
          "text": "以原告不具备出借能力或款项来源不明为由驳回起诉，属于将实体审查前置，违反诉讼程序",
          "status": "unverified",
          "linked_evidence_ids": []
        }
