    {
      "issue_id": "issue-civil-loan-012-003",
      "case_id": "civil-loan-012",
      "title": "《民间借贷规定》第2条第2款关于债权人资格抗辩的适用条件",
      "issue_type": "legal",
      "parent_issue_id": "issue-civil-loan-012-001",
      "related_claim_ids": [
        "claim-civil-loan-012-001"
      ],
      "related_defense_ids": [
        "defense-civil-loan-012-002"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-012-006",
          "text": "《民间借贷规定》第2条第2款关于\"被告提出原告不具有债权人资格\"的抗辩，其适用前提为债权凭证没有载明债权人",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-012-007",
          "text": "本案债权凭证（借款合同）明确载明原告为债权人，不符合上述条款的适用前提",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-012-001"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-012-008",
          "text": "债权凭证载明债权人的情况下，被告关于原告非实际出借人的主张应通过实体审理解决，不得据此驳回起诉",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
