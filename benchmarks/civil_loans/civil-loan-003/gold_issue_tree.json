      "parent_issue_id": "issue-civil-loan-003-002",
      "related_claim_ids": [],
      "related_defense_ids": ["defense-civil-loan-003-001"],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-003-008",
          "text": "'代为偿还'在文义上既可理解为债务加入也可理解为债务转移，不能仅凭该措辞当然认定债务已转移",
          "status": "verified",
          "linked_evidence_ids": ["evidence-civil-loan-003-003"]
        }
      ],
      "burden_ids": ["burden-civil-loan-003-004"],
      "evidence_ids": ["evidence-civil-loan-003-003"],
      "status": "resolved"
    },
    {
