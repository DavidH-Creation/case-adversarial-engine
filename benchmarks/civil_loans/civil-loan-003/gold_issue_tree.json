    {
      "issue_id": "issue-civil-loan-003-002",
      "case_id": "civil-loan-003",
      "title": "第三人与债权人签订的还款协议的法律性质认定（债务加入还是债务转移）",
      "issue_type": "legal",
      "parent_issue_id": null,
      "related_claim_ids": ["claim-civil-loan-003-002"],
      "related_defense_ids": ["defense-civil-loan-003-001"],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-003-003",
          "text": "第三人以自己名义与债权人签订还款协议，约定分期代为偿还债务人所欠借款及利息",
          "status": "verified",
          "linked_evidence_ids": ["evidence-civil-loan-003-003"]
        },
        {
          "proposition_id": "fp-civil-loan-003-004",
          "text": "还款协议使用了'代为偿还'的表述，而非'承担全部债务'或'替代债务人'",
          "status": "verified",
          "linked_evidence_ids": ["evidence-civil-loan-003-003"]
        },
        {
          "proposition_id": "fp-civil-loan-003-005",
          "text": "原借款合同的内容并未因还款协议的签订而发生变更",
          "status": "verified",
          "linked_evidence_ids": ["evidence-civil-loan-003-001", "evidence-civil-loan-003-003"]
        },
        {
          "proposition_id": "fp-civil-loan-003-006",
          "text": "债权人没有明确表示免除原债务人的清偿义务",
          "status": "verified",
          "linked_evidence_ids": ["evidence-civil-loan-003-005"]
        },
        {
          "proposition_id": "fp-civil-loan-003-007",
          "text": "债权人明确表示不认可债务已经转移",
          "status": "verified",
          "linked_evidence_ids": ["evidence-civil-loan-003-005"]
        }
      ],
      "burden_ids": ["burden-civil-loan-003-002", "burden-civil-loan-003-003"],
      "evidence_ids": ["evidence-civil-loan-003-001", "evidence-civil-loan-003-003", "evidence-civil-loan-003-005"],
      "status": "resolved"
    },
    {
      "issue_id": "issue-civil-loan-003-003",
      "case_id": "civil-loan-003",
      "title": "'代为偿还'一词能否当然认定为债务转移",
