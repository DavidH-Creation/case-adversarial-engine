    {
      "issue_id": "issue-civil-loan-014-003",
      "case_id": "civil-loan-014",
      "title": "一人公司股东是否能证明公司财产独立于股东个人财产（财产混同认定）",
      "issue_type": "mixed",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-014-002"
      ],
      "related_defense_ids": [
        "defense-civil-loan-014-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-014-004",
          "text": "股东未能提交经审计的公司年度财务会计报告以证明财产独立",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-014-005"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-014-005",
          "text": "公司账户与股东个人账户之间存在频繁的资金往来，难以区分公司财产与个人财产",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-014-006"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-014-006",
          "text": "公司未建立独立规范的财务制度或财务制度形同虚设",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-014-005"
          ]
        }
      ],
