    {
      "issue_id": "issue-civil-loan-014-004",
      "case_id": "civil-loan-014",
      "title": "举证责任倒置规则的适用（《公司法》第六十三条）",
      "issue_type": "legal",
      "parent_issue_id": "issue-civil-loan-014-003",
      "related_claim_ids": [
        "claim-civil-loan-014-002"
      ],
      "related_defense_ids": [
        "defense-civil-loan-014-001"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-014-007",
          "text": "依据《公司法》第六十三条，一人有限责任公司的股东不能证明公司财产独立于股东自己的财产的，应当对公司债务承担连带责任",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-014-008",
          "text": "债权人无需举证证明财产混同，举证责任由被告股东承担（举证责任倒置）",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
      "burden_ids": [
        "burden-civil-loan-014-003"
      ],
      "evidence_ids": [],
      "status": "open"
    },
    {
      "issue_id": "issue-civil-loan-014-005",
      "case_id": "civil-loan-014",
      "title": "股东缺席审判的法律后果",
      "issue_type": "procedural",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-014-002"
      ],
      "related_defense_ids": [
        "defense-civil-loan-014-002"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-014-009",
          "text": "股东经法院合法传唤后未到庭应诉亦未委托代理人出庭",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-014-007"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-014-010",
          "text": "股东未到庭应诉视为放弃质证和抗辩权利，应承担相应不利后果",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-014-007"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-014-011",
          "text": "在举证责任倒置的情形下，股东缺席进一步导致其无法完成证明公司财产独立的举证义务",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
