    {
      "issue_id": "issue-civil-loan-011-003",
      "case_id": "civil-loan-011",
      "title": "收购承诺的法律性质——增信措施还是独立合同义务",
      "issue_type": "legal",
      "parent_issue_id": null,
      "related_claim_ids": [
        "claim-civil-loan-011-003"
      ],
      "related_defense_ids": [
        "defense-civil-loan-011-002",
        "defense-civil-loan-011-003"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-011-006",
          "text": "担保人向银行出具书面承诺：借款人未按约还款时，将以不低于未获清偿借款本息的价格收购抵押物和质物",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-011-006"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-011-007",
          "text": "该收购承诺的目的在于提高抵押物和质物的变现能力，为银行债权提供增信",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-011-006",
            "evidence-civil-loan-011-007"
          ]
        },
        {
          "proposition_id": "fp-civil-loan-011-008",
          "text": "收购承诺的履行条件取决于主债务人是否违约，具有从属性和补充性",
          "status": "unverified",
          "linked_evidence_ids": [
            "evidence-civil-loan-011-006"
          ]
        }
      ],
