    {
      "issue_id": "issue-civil-loan-011-004",
      "case_id": "civil-loan-011",
      "title": "收购承诺是否应认定为非典型保证",
      "issue_type": "legal",
      "parent_issue_id": "issue-civil-loan-011-003",
      "related_claim_ids": [
        "claim-civil-loan-011-003"
      ],
      "related_defense_ids": [
        "defense-civil-loan-011-003"
      ],
      "fact_propositions": [
        {
          "proposition_id": "fp-civil-loan-011-009",
          "text": "收购承诺实质上是担保人以自身信用为主债务提供担保，符合保证的核心特征",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-011-010",
          "text": "收购承诺虽不采用典型保证合同形式，但具有从属性、补充性、单务性等保证基本属性",
          "status": "unverified",
          "linked_evidence_ids": []
        },
        {
          "proposition_id": "fp-civil-loan-011-011",
          "text": "依据《民法典》担保司法解释第36条，第三人提供的增信措施具有担保功能的，可参照保证规则处理",
          "status": "unverified",
          "linked_evidence_ids": []
        }
      ],
      "burden_ids": [
        "burden-civil-loan-011-004"
      ],
      "evidence_ids": [
        "evidence-civil-loan-011-006"
      ],
      "status": "open"
    },
    {
      "issue_id": "issue-civil-loan-011-005",
      "case_id": "civil-loan-011",
      "title": "担保人承担补充赔偿责任的范围与顺序",
